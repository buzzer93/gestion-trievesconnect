{% extends 'base.html.twig' %}

{% block title %}Inscription · Trieves Connect Manager{% endblock %}

{% block body %}
    <div class="flex justify-center py-8 sm:py-16">
        <div class="w-full max-w-md">
            <div class="text-center mb-6">
                <h1 class="mb-2">Créer un compte</h1>
                <p class="text-text-soft m-0">
                    Rejoignez Trieves Connect en quelques secondes.
                </p>
            </div>

            {% for flash_error in app.flashes('verify_email_error') %}
                {% include 'components/_alert.html.twig' with {
                    type: 'error',
                    message: flash_error,
                } only %}
            {% endfor %}

            {% embed 'components/_card.html.twig' with {
                elevated: true,
                padding: 'lg',
                registrationForm: registrationForm,
            } only %}
                {% block body %}
                    {{ form_start(registrationForm, { attr: { class: 'space-y-3' } }) }}
                        {{ form_errors(registrationForm) }}

                        {{ form_row(registrationForm.username) }}
                        {{ form_row(registrationForm.email) }}
                        {{ form_row(registrationForm.plainPassword, { label: 'Mot de passe' }) }}
                        {{ form_row(registrationForm.agreeTerms) }}

                        <div class="pt-2">
                            {% include 'components/_button.html.twig' with {
                                label: 'S\'inscrire',
                                variant: 'accent',
                                size: 'lg',
                                type: 'submit',
                                icon: 'fa-solid fa-user-plus',
                                extra_class: 'w-full',
                            } only %}
                        </div>
                    {{ form_end(registrationForm) }}

                    <p class="mt-5 text-sm text-text-muted text-center">
                        Déjà un compte ?
                        <a href="{{ path('login') }}" class="font-bold uppercase tracking-wide text-accent hover:text-link-hover">Se connecter</a>
                    </p>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
{% endblock %}
