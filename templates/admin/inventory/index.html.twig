{% extends 'base.html.twig' %}

{% block title %}Inventaire · Trieves Connect Manager{% endblock %}

{% block body %}
    {% include 'components/_page_header.html.twig' with {
        title: 'Inventaire',
        subtitle: 'Saisie et suivi du stock.',
    } only %}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
        {# Formulaire ajout — 2/3 colonne #}
        <div class="lg:col-span-2 bg-surface-300 border border-border rounded-md p-6 shadow-ambient">
            {{ form_start(form) }}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="{{ form.barCode.vars.id }}"
                           class="block text-xs font-bold uppercase tracking-wide text-text-soft mb-1.5">Code-barre</label>
                    {{ form_widget(form.barCode, {'attr': {'class': 'block w-full bg-surface-200 text-text-primary border border-border rounded-sm px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent transition-colors'}}) }}
                </div>
                <div>
                    <label for="{{ form.quantity.vars.id }}"
                           class="block text-xs font-bold uppercase tracking-wide text-text-soft mb-1.5">Quantité</label>
                    {{ form_widget(form.quantity, {'attr': {'class': 'block w-full bg-surface-200 text-text-primary border border-border rounded-sm px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent transition-colors'}}) }}
                </div>
            </div>
            <div class="mt-5 flex justify-end">
                {{ form_widget(form.save, {'attr': {'class': 'inline-flex items-center justify-center gap-2 bg-transparent text-text-primary border-2 border-accent font-display font-bold uppercase tracking-wide text-sm px-6 py-2 rounded-md hover:bg-accent hover:text-bg transition-colors'}}) }}
            </div>
            {{ form_end(form) }}
        </div>

        {# Recherche + suppression globale — 1/3 colonne #}
        <div class="flex flex-col gap-4">
            <div>
                <label for="filterInput" class="block text-xs font-bold uppercase tracking-wide text-text-soft mb-1.5">Recherche</label>
                <input type="text" id="filterInput"
                       placeholder="Filtrer un produit"
                       class="block w-full bg-surface-200 text-text-primary border border-border rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent transition-colors">
            </div>
            <form method="post"
                  action="{{ path('admin.inventory.delete', { id: 0, all: 'true' }) }}"
                  onsubmit="return confirm('Voulez-vous vraiment supprimer tous les produits de l\'inventaire ?');">
                <input type="hidden" name="_method" value="DELETE">
                <button type="submit"
                        class="w-full inline-flex items-center justify-center gap-2 bg-transparent text-error border-2 border-error font-display font-bold uppercase tracking-wide text-sm px-4 py-2.5 rounded-md hover:bg-error hover:text-text-primary transition-colors">
                    <i class="fa-solid fa-trash" aria-hidden="true"></i>
                    <span>Supprimer tout</span>
                </button>
            </form>
        </div>
    </div>

    <div class="flex items-center justify-between mb-5 px-1">
        <h2 class="m-0">Total de l'inventaire</h2>
        <span class="font-mono font-bold text-2xl text-accent">{{ inventoryValue | number_format(2, ',', ' ') }} €</span>
    </div>

    <table class="data-table" id="productTable">
        <thead>
            <tr>
                <th>Nom</th>
                <th class="text-right">Prix d'achat HT</th>
                <th class="text-right">Quantité</th>
                <th>Code-barre</th>
                <th class="text-right">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for product in inventoryList %}
                <tr data-controller="row-link"
                    data-row-link-url-value="{{ path('admin.' ~ product.getType() ~ '.edit', { id: product.id }) }}">
                    <td>
                        <a class="product_name" href="{{ path('admin.' ~ product.getType() ~ '.edit', { id: product.id }) }}">{{ product.name }}</a>
                    </td>
                    <td class="text-right font-mono text-sm">{{ product.purchasePrice | number_format(2, ',', ' ') }} €</td>
                    <td class="text-right font-mono text-sm">{{ product.stock }}</td>
                    <td><span class="bareCode">{{ product.barCode }}</span></td>
                    <td>
                        <div class="flex justify-end">
                            <form method="post"
                                  action="{{ path('admin.inventory.delete', { id: product.id, all: 'false' }) }}"
                                  onsubmit="return confirm('Voulez-vous vraiment supprimer ce produit de l\'inventaire ?');">
                                <input type="hidden" name="_method" value="DELETE">
                                {% include 'components/_button.html.twig' with {
                                    label: 'Supprimer',
                                    variant: 'danger',
                                    size: 'sm',
                                    type: 'submit',
                                    icon: 'fa-solid fa-trash',
                                } only %}
                            </form>
                        </div>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <script src="{{ asset('js/preventDefault.js') }}"></script>
    <script src="{{ asset('js/filter.js') }}"></script>
{% endblock %}
