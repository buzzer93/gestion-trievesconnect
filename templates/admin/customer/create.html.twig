{% extends './base.html.twig' %}

{% block title %}
	Nouveau Client
{% endblock %}

{% block body %}

	<h1 class="text-center">Nouveau Client</h1>

	<div class="container d-flex justify-content-center px-5">
		{{ form_start(form, { 'attr': { 'id': 'form' } }) }}
		{{ form_errors(form) }}
		<div class="row">
			<div class="col-sm">{{ form_row(form.name) }}</div>
			<div class="col-sm">{{ form_row(form.phoneNumber) }}</div>
			<div class="col-sm">{{ form_row(form.email) }}</div>
		</div>
		<div class="row">
			<div class="col-sm">{{ form_row(form.address) }}</div>
			<div class="col-sm">{{ form_row(form.postalCode) }}</div>
			<div class="col-sm">{{ form_row(form.city) }}</div>
		</div>
		<div class="row">
			<div class="col-sm">{{ form_row(form.balanceEuros) }}</div>
		</div>
		<div class="row">
			<div class="col-sm d-flex gap-2 align-items-end">
				<div>{{ form_widget(form.save, { attr: { class: 'btn btn-primary' } }) }}</div>
				<a href="{{ path('admin.customer.index') }}" class="btn btn-secondary">Annuler</a>
			</div>
		</div>

		{{ form_end(form) }}
	</div>
	<script src="{{ asset('js/margin.js') }}"></script>
	<script src="{{ asset('js/preventDefault.js') }}"></script>
{% endblock %}
