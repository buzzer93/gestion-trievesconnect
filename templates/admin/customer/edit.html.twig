{% extends 'base.html.twig' %}

{% block title %}Client : {{ customer.name ?? '' }} · Trieves Connect Manager{% endblock %}

{% block body %}
    {% embed 'components/_page_header.html.twig' with {
        title: customer.name,
        subtitle: 'Informations et solde client.',
        customer: customer,
    } only %}
        {% block actions %}
            {% include 'components/_button.html.twig' with {
                label: 'Imprimer carte client',
                variant: 'primary',
                icon: 'fa-solid fa-id-card',
                href: path('admin.customer.card_print', {id: customer.id}),
            } only %}
            {% include 'components/_button.html.twig' with {
                label: 'Retour',
                variant: 'ghost',
                icon: 'fa-solid fa-arrow-left',
                href: path('admin.customer.index'),
            } only %}
        {% endblock %}
    {% endembed %}

    {% embed 'components/_card.html.twig' with { padding: 'lg', form: form } only %}
        {% block body %}
            {{ form_start(form, { attr: { id: 'form' } }) }}
                {{ form_errors(form) }}

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    {{ form_row(form.name) }}
                    {{ form_row(form.phoneNumber) }}
                    {{ form_row(form.email) }}
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="md:col-span-2">{{ form_row(form.address) }}</div>
                    <div>{{ form_row(form.postalCode) }}</div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    {{ form_row(form.city) }}
                    {{ form_row(form.balanceEuros, { label: 'Solde (€)' }) }}
                </div>

                <div class="flex items-center gap-3 mt-6 pt-4 border-t border-border">
                    {{ form_widget(form.save, { attr: { class: 'inline-flex items-center justify-center gap-2 bg-accent text-bg font-display font-semibold text-sm px-4 py-2 rounded-md border border-accent hover:bg-accent-hover hover:border-accent-hover transition-colors duration-150 focus:outline-none focus:shadow-focus' } }) }}
                    {% include 'components/_button.html.twig' with {
                        label: 'Annuler',
                        variant: 'ghost',
                        href: path('admin.customer.index'),
                    } only %}
                </div>
            {{ form_end(form) }}
        {% endblock %}
    {% endembed %}

    <script src="{{ asset('js/margin.js') }}"></script>
    <script src="{{ asset('js/preventDefault.js') }}"></script>
{% endblock %}
