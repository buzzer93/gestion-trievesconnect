{% extends './base.html.twig' %}

{% block body %}
	<div class="row">
		{% for item in dataList %}
			{% set data = item.entity %}
			{% set format = item.format %}
			<div class="label {{ format == 'large' ? 'label-large' : 'label-small' }}">
				<div class="label-content">
					{% if format == 'large' %}
						<div class="label-left">
							<p class="label-text">
								{{ data.getLabelingName | raw }}
							</p>
							<p class="label-price">
								<strong>{{ data.sellingPrice | number_format(2, ',', ' ') }} €</strong> TTC
							</p>
						</div>
						<div class="label-right">
							<img src="{{ data.getBarCodeImage() }}" alt="Code-barres" class="barcode-img">
						</div>
					{% else %}
						<p class="label-text">
							{{ data.getLabelingName | raw }}<br>
							<strong>{{ data.sellingPrice | number_format(2, ',', ' ') }} €</strong> TTC<br>
							<img src="{{ data.getBarCodeImage() }}" alt="Code-barres" class="barcode-img">
						</p>
					{% endif %}
				</div>
			</div>
		{% endfor %}
	</div>
	<script>
		setTimeout(window.print(), 1000);

		// Redirige après 1 seconde
		setTimeout(function () {
			window.location.href = "{{ path('admin.labeling.index') }}";
		}, 1000);
	</script>
{% endblock %}


{% block stylesheets %}
	<style>
		/* === Conteneur de labels === */
		.row {
			display: flex;
			flex-wrap: wrap;
			gap: 0;
			align-content: flex-start;
		}

		/* === Base commune === */
		.label {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
			border: 1px solid black;
			background-color: white;
			display: flex;
			align-items: center;
			justify-content: center;
			flex-shrink: 0;
		}

		.label-content {
			width: 100%;
			height: 100%;
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.label-text {
			margin: 0;
			text-align: center;
			font-size: 24px;
			line-height: 1.2;
			color: #000;
		}

		/* === Petit format : 6cm x 4cm === */
		.label-small {
			width: 6cm;
			height: 4cm;
			flex-direction: column;
		}

		.label-small .label-content {
			flex-direction: column;
			width: 100%;
			padding: 2px 8px;
			box-sizing: border-box;
		}

		.label-small .label-text {
			width: 100%;
		}

		.label-small .barcode-img {
			display: block;
			width: 100%;
			height: auto;
			max-height: 1.8cm;
			object-fit: contain;
			margin-top: 4px;
		}

		/* === Grand format : 12cm x 4cm === */
		.label-large {
			width: 12cm;
			height: 4cm;
		}

		.label-large .label-content {
			flex-direction: row;
			justify-content: space-between;
			padding: 0 0.5cm;
		}

		.label-large .label-left {
			display: flex;
			flex-direction: column;
			justify-content: center;
			flex: 1;
			padding-left: 0.3cm;
		}

		.label-large .label-text {
			font-size: 36px;
		}

		.label-large .label-price {
			margin: 5px 0 0 0;
			text-align: center;
			font-size: 35px;
			color: #000;
		}

		.label-large .label-right {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 3cm;
			height: 100%;
			overflow: visible;
		}

		.label-large .barcode-img {
			transform: rotate(-90deg);
			width: 3.5cm;   /* devient la HAUTEUR visuelle après rotation (padding ~0.25cm haut/bas) */
			height: 2.9cm;  /* devient la LARGEUR visuelle après rotation */
			max-width: none; /* override Tailwind preflight max-width: 100% */
			object-fit: contain;
		}

		/* === Styles d'impression === */
		@media print {
			.label {
				page-break-inside: avoid;
			}
		}
	</style>
{% endblock %}
