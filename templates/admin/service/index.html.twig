{% extends 'base.html.twig' %}

{% block title %}Services · Trieves Connect Manager{% endblock %}

{% block body %}
    {% embed 'components/_page_header.html.twig' with {
        title: 'Services',
        subtitle: 'Catalogue des services facturables.',
    } only %}
        {% block actions %}
            {% include 'components/_button.html.twig' with {
                label: 'Nouveau service',
                variant: 'accent',
                icon: 'fa-solid fa-plus',
                href: path('admin.service.create'),
            } only %}
        {% endblock %}
    {% endembed %}

    <div class="mb-4 max-w-md">
        <label for="filterInput" class="block text-sm font-medium text-text-soft mb-1.5">
            Filtrer par code-barre
        </label>
        <input type="text" id="filterInput"
               placeholder="Saisir ou scanner un code-barre"
               autocomplete="off"
               class="block w-full bg-surface-200 text-text-primary border border-border rounded-md px-3 py-2 text-sm font-mono placeholder:text-text-muted focus:outline-none focus:border-accent focus:shadow-focus">
    </div>

    <table class="data-table" id="sortableTable">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Prix vente TTC</th>
                <th>Marge</th>
                <th>Code-barre</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for service in services %}
                <tr data-controller="row-link"
                    data-row-link-url-value="{{ path('admin.service.edit', {id: service.id}) }}">
                    <td>
                        <a class="service_name" href="{{ path('admin.service.edit', {id: service.id}) }}">{{ service.name }}</a>
                    </td>
                    <td>{{ service.sellingPrice|number_format(2, ',', ' ') }} €</td>
                    <td class="text-text-soft">{{ service.marginAmount|number_format(2, ',', ' ') }} €</td>
                    <td><span class="bareCode">{{ service.barCode }}</span></td>
                    <td>
                        <div class="flex justify-center gap-2">
                            <form method="post" action="{{ path('admin.service.delete', {id: service.id}) }}"
                                  onsubmit="return confirm('Supprimer ce service ?');">
                                <input type="hidden" name="_method" value="DELETE">
                                {% include 'components/_button.html.twig' with {
                                    label: 'Supprimer',
                                    variant: 'danger',
                                    size: 'sm',
                                    type: 'submit',
                                    icon: 'fa-solid fa-trash',
                                } only %}
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center text-text-muted italic font-serif py-6">
                        Aucun service pour l'instant.
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <script src="{{ asset('js/filter.js') }}"></script>
{% endblock %}
