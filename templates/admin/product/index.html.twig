{% extends 'base.html.twig' %}

{% block title %}Produits · Trieves Connect Manager{% endblock %}

{% block body %}
    {% embed 'components/_page_header.html.twig' with {
        title: 'Produits',
        subtitle: 'Catalogue, marges et codes-barres.',
    } only %}
        {% block actions %}
            {% include 'components/_button.html.twig' with {
                label: 'Exporter',
                variant: 'primary',
                size: 'md',
                icon: 'fa-solid fa-download',
                href: path('admin.product.export'),
            } only %}
            {% include 'components/_button.html.twig' with {
                label: 'Nouveau produit',
                variant: 'accent',
                icon: 'fa-solid fa-plus',
                href: path('admin.product.create'),
            } only %}
        {% endblock %}
    {% endembed %}

    <div class="mb-4 max-w-md">
        <label for="filterInput" class="block text-sm font-medium text-text-soft mb-1.5">
            Filtrer par code-barre
        </label>
        <input type="text" id="filterInput"
               placeholder="Saisir ou scanner un code-barre"
               autocomplete="off"
               class="block w-full bg-surface-200 text-text-primary border border-border rounded-md px-3 py-2 text-sm font-mono placeholder:text-text-muted focus:outline-none focus:border-accent focus:shadow-focus">
    </div>

    <div class="overflow-x-auto">
        <table class="data-table" id="sortableTable">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Achat HT</th>
                    <th>Vente TTC</th>
                    <th>Marge</th>
                    <th>Montant marge</th>
                    <th>Marque</th>
                    <th>Fournisseur</th>
                    <th>Code-barre</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for product in products %}
                    <tr data-controller="row-link"
                        data-row-link-url-value="{{ path('admin.product.edit', {id: product.id}) }}">
                        <td>
                            <a class="product_name" href="{{ path('admin.product.edit', {id: product.id}) }}">{{ product.name }}</a>
                        </td>
                        <td>{{ product.purchasePrice|number_format(2, ',', ' ') }} €</td>
                        <td>{{ product.sellingPrice|number_format(2, ',', ' ') }} €</td>
                        <td class="text-text-soft">{{ product.marginRate }}%</td>
                        <td class="text-text-soft">{{ product.marginAmount|number_format(2, ',', ' ') }} €</td>
                        <td class="text-text-soft">{{ product.markRate }}%</td>
                        <td>{{ product.supplier }}</td>
                        <td><span class="bareCode">{{ product.barCode }}</span></td>
                        <td>
                            <div class="flex justify-center gap-2">
                                <form method="post" action="{{ path('admin.product.delete', {id: product.id}) }}"
                                      onsubmit="return confirm('Supprimer ce produit ?');">
                                    <input type="hidden" name="_method" value="DELETE">
                                    {% include 'components/_button.html.twig' with {
                                        label: 'Supprimer',
                                        variant: 'danger',
                                        size: 'sm',
                                        type: 'submit',
                                        icon: 'fa-solid fa-trash',
                                    } only %}
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" class="text-center text-text-muted italic font-serif py-6">
                            Aucun produit pour l'instant.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <script src="{{ asset('js/filter.js') }}"></script>
{% endblock %}
