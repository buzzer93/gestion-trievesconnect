{% extends 'base.html.twig' %}

{% block title %}Produit : {{ product.name }} · Trieves Connect Manager{% endblock %}

{% block body %}
    {% embed 'components/_page_header.html.twig' with {
        title: product.name,
        subtitle: 'Modifier les caractéristiques, tarifs et catégories.',
    } only %}
        {% block actions %}
            {% include 'components/_button.html.twig' with {
                label: 'Retour',
                variant: 'ghost',
                icon: 'fa-solid fa-arrow-left',
                href: path('admin.product.index'),
            } only %}
        {% endblock %}
    {% endembed %}

    {% embed 'components/_card.html.twig' with { padding: 'lg', form: form } only %}
        {% block body %}
            {{ form_start(form, { attr: { id: 'form' } }) }}
                {{ form_errors(form) }}

                <div class="grid grid-cols-1 md:grid-cols-6 gap-4">
                    <div class="md:col-span-3">{{ form_row(form.name) }}</div>
                    <div class="md:col-span-2">{{ form_row(form.barCode) }}</div>
                    <div class="md:col-span-1">{{ form_row(form.supplier) }}</div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    {{ form_row(form.purchasePrice) }}
                    {{ form_row(form.marginRate) }}
                    {{ form_row(form.sellingPrice) }}
                </div>

                <div class="mb-4">
                    <span class="block text-sm font-medium text-text-soft mb-2">
                        {{ form_label(form.categories) }}
                    </span>
                    <div class="flex flex-wrap gap-x-5 gap-y-2 bg-surface-200 border border-border rounded-md p-3">
                        {{ form_widget(form.categories) }}
                    </div>
                </div>

                {{ form_row(form.comment) }}

                <div class="flex items-center gap-3 mt-6 pt-4 border-t border-border">
                    {{ form_widget(form.save, { attr: { class: 'inline-flex items-center justify-center gap-2 bg-accent text-bg font-display font-semibold text-sm px-4 py-2 rounded-md border border-accent hover:bg-accent-hover hover:border-accent-hover transition-colors duration-150 focus:outline-none focus:shadow-focus' } }) }}
                    {% include 'components/_button.html.twig' with {
                        label: 'Annuler',
                        variant: 'ghost',
                        href: path('admin.product.index'),
                    } only %}
                </div>
            {{ form_end(form) }}
        {% endblock %}
    {% endembed %}

    <script src="{{ asset('js/margin.js') }}"></script>
    <script src="{{ asset('js/preventDefault.js') }}"></script>
{% endblock %}
