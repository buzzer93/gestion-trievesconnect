{% extends 'base.html.twig' %}

{% block title %}Nouveau produit · Trieves Connect Manager{% endblock %}

{% block body %}
    {% embed 'components/_page_header.html.twig' with {
        title: 'Nouveau produit',
        subtitle: 'Ajouter un article au catalogue.',
    } only %}
        {% block actions %}
            {% include 'components/_button.html.twig' with {
                label: 'Retour',
                variant: 'ghost',
                icon: 'fa-solid fa-arrow-left',
                href: path('admin.product.index'),
            } only %}
        {% endblock %}
    {% endembed %}

    {% embed 'components/_card.html.twig' with { padding: 'lg', form: form } only %}
        {% block body %}
            {{ form_start(form, { attr: { id: 'form' } }) }}
                {{ form_errors(form) }}

                {% include 'admin/product/_form_fields.html.twig' with { form: form } only %}

                <div class="flex items-center gap-3 mt-6 pt-4 border-t border-border">
                    {{ form_widget(form.save, { attr: { class: 'inline-flex items-center justify-center gap-2 bg-accent text-bg font-display font-semibold text-sm px-4 py-2 rounded-md border border-accent hover:bg-accent-hover hover:border-accent-hover transition-colors duration-150 focus:outline-none focus:shadow-focus' } }) }}
                    {% include 'components/_button.html.twig' with {
                        label: 'Annuler',
                        variant: 'ghost',
                        href: path('admin.product.index'),
                    } only %}
                </div>
            {{ form_end(form) }}
        {% endblock %}
    {% endembed %}

    <script src="{{ asset('js/margin.js') }}"></script>
    <script src="{{ asset('js/preventDefault.js') }}"></script>
{% endblock %}
