{% extends 'base.html.twig' %}

{% block title %}Catégories · Trieves Connect Manager{% endblock %}

{% block body %}
    {% embed 'components/_page_header.html.twig' with {
        title: 'Catégories',
        subtitle: 'Regroupement des produits par thème.',
    } only %}
        {% block actions %}
            {% include 'components/_button.html.twig' with {
                label: 'Nouvelle catégorie',
                variant: 'accent',
                icon: 'fa-solid fa-plus',
                href: path('admin.category.create'),
            } only %}
        {% endblock %}
    {% endembed %}

    <table class="data-table" id="categoryTable">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Produits affiliés</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for category in categories %}
                <tr data-controller="row-link"
                    data-row-link-url-value="{{ path('admin.category.edit', {id: category.id}) }}">
                    <td>
                        <a class="data_name" href="{{ path('admin.category.edit', {id: category.id}) }}">{{ category.name }}</a>
                    </td>
                    <td>
                        {% include 'components/_pill.html.twig' with {
                            label: category.count,
                            tone: 'neutral',
                        } only %}
                    </td>
                    <td>
                        <div class="flex justify-center gap-2">
                            <form method="post" action="{{ path('admin.category.delete', {id: category.id}) }}"
                                  onsubmit="return confirm('Supprimer cette catégorie ?');">
                                <input type="hidden" name="_method" value="DELETE">
                                {% include 'components/_button.html.twig' with {
                                    label: 'Supprimer',
                                    variant: 'danger',
                                    size: 'sm',
                                    type: 'submit',
                                    icon: 'fa-solid fa-trash',
                                } only %}
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3" class="text-center text-text-muted italic font-serif py-6">
                        Aucune catégorie pour l'instant.
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
