<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Trieves Connect Manager{% endblock %}</title>
    <link rel="icon" href="https://gestion.trievesconnect.fr/image/favicon.ico">

    {# Préconnexion Google Fonts pour limiter la latence #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    {# Polices NVIDIA dark : Inter (UI), JetBrains Mono (code/barcodes) #}
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    {# FontAwesome icônes #}
    <script src="https://kit.fontawesome.com/9075c6e930.js" crossorigin="anonymous"></script>

    {% block stylesheets %}{% endblock %}

    {# Tailwind v4 + design system NVIDIA dark chargé via AssetMapper (assets/styles/app.css) #}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>

{% set is_print_route = app.current_route ends with '.print' or app.current_route ends with '.card_print' %}

<body class="min-h-screen bg-bg text-text-primary font-display antialiased {{ is_print_route ? 'is-print' : '' }}">

    {% if not is_print_route %}
        {% set route = app.current_route %}
        {% set nav_links = [
            { route: 'admin.customer.',  href: path('admin.customer.index'),  label: 'Clients' },
            { route: 'admin.product.',   href: path('admin.product.index'),   label: 'Produits' },
            { route: 'admin.service.',   href: path('admin.service.index'),   label: 'Services' },
            { route: 'admin.category.',  href: path('admin.category.index'),  label: 'Catégories' },
            { route: 'admin.labeling.',  href: path('admin.labeling.index'),  label: 'Étiquetage' },
            { route: 'admin.inventory.', href: path('admin.inventory.index'), label: 'Inventaire' },
        ] %}

        <nav class="sticky top-0 z-40 bg-bg border-b-2 border-accent shadow-ambient"
             data-controller="dropdown">
            <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">

                {# Brand : wordmark NVIDIA-style en uppercase #}
                <a href="{{ path('home.index') }}"
                   class="flex items-center gap-2.5 shrink-0 text-text-primary hover:text-text-primary no-underline">
                    <img src="https://gestion.trievesconnect.fr/image/favicon.ico" alt="Logo"
                         class="h-7 w-7 object-contain">
                    <span class="font-display font-bold text-sm uppercase tracking-wide">Trieves Connect</span>
                </a>

                {# Liens desktop : uppercase 14px weight 700, hover bleu NVIDIA #}
                <ul class="hidden md:flex items-center gap-1 list-none m-0 p-0">
                    {% for link in nav_links %}
                        {% set active = route starts with link.route %}
                        <li>
                            <a href="{{ link.href }}"
                               class="inline-flex items-center px-3 py-2 text-xs font-bold uppercase tracking-wide transition-colors duration-150
                                      {{ active
                                        ? 'text-text-primary border-b-2 border-accent -mb-px'
                                        : 'text-text-soft hover:text-text-primary' }}">
                                {{ link.label }}
                            </a>
                        </li>
                    {% endfor %}
                </ul>

                {# Auth + burger #}
                <div class="flex items-center gap-2">
                    {% if is_granted('ROLE_USER') %}
                        <a href="{{ path('logout') }}"
                           class="hidden md:inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold uppercase tracking-wide text-text-soft hover:text-error transition-colors duration-150">
                            <i class="fa-solid fa-right-from-bracket text-xs" aria-hidden="true"></i>
                            <span>Se déconnecter</span>
                        </a>
                    {% else %}
                        <a href="{{ path('login') }}"
                           class="hidden md:inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold uppercase tracking-wide text-text-primary border-2 border-accent rounded-md hover:bg-btn-hover hover:text-text-primary transition-colors duration-150">
                            <i class="fa-solid fa-right-to-bracket text-xs" aria-hidden="true"></i>
                            <span>Se connecter</span>
                        </a>
                    {% endif %}

                    {# Burger mobile #}
                    <button type="button"
                            data-dropdown-target="button"
                            data-action="dropdown#toggle"
                            class="md:hidden inline-flex items-center justify-center w-9 h-9 rounded-sm text-text-soft hover:text-text-primary hover:bg-surface-300 transition-colors"
                            aria-expanded="false" aria-controls="mobile-menu" aria-label="Menu">
                        <i class="fa-solid fa-bars" aria-hidden="true"></i>
                    </button>
                </div>
            </div>

            {# Menu mobile #}
            <div id="mobile-menu" data-dropdown-target="menu" class="hidden md:hidden border-t border-border bg-surface-300">
                <ul class="list-none m-0 p-2 space-y-1">
                    {% for link in nav_links %}
                        {% set active = route starts with link.route %}
                        <li>
                            <a href="{{ link.href }}"
                               class="block px-3 py-2 text-xs font-bold uppercase tracking-wide transition-colors
                                      {{ active
                                        ? 'text-text-primary border-l-2 border-accent bg-surface-400'
                                        : 'text-text-soft hover:text-text-primary hover:bg-surface-400' }}">
                                {{ link.label }}
                            </a>
                        </li>
                    {% endfor %}
                    <li class="pt-2 mt-2 border-t border-border">
                        {% if is_granted('ROLE_USER') %}
                            <a href="{{ path('logout') }}"
                               class="block px-3 py-2 text-xs font-bold uppercase tracking-wide text-text-soft hover:text-error">
                                <i class="fa-solid fa-right-from-bracket mr-1.5" aria-hidden="true"></i>
                                Se déconnecter
                            </a>
                        {% else %}
                            <a href="{{ path('login') }}"
                               class="block px-3 py-2 text-xs font-bold uppercase tracking-wide text-text-primary border-l-2 border-accent">
                                <i class="fa-solid fa-right-to-bracket mr-1.5" aria-hidden="true"></i>
                                Se connecter
                            </a>
                        {% endif %}
                    </li>
                </ul>
            </div>
        </nav>
    {% endif %}

    <main class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
        {% include "partials/flash.html.twig" %}
        {% block body %}{% endblock %}
    </main>

    {# simple-datatables conservé pour les tables admin (autonome, sans Bootstrap) #}
    <script src="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/umd/simple-datatables.min.js" crossorigin="anonymous"></script>
    <script src="{{ asset('js/datatables/datatables-simple-demo.js') }}"></script>
</body>
</html>
