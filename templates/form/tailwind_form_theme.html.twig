{#
  form/tailwind_form_theme.html.twig
  Form theme Tailwind / NVIDIA dark pour Symfony Forms.

  Activation locale :
    {% form_theme form 'form/tailwind_form_theme.html.twig' %}

  Activation globale (config/packages/twig.yaml) :
    twig:
        form_themes: ['form/tailwind_form_theme.html.twig']

  Surcharges :
    - form_row, form_label, form_widget_simple
    - textarea_widget, choice_widget_collapsed
    - checkbox_widget, radio_widget
    - form_errors, form_help
    - submit_widget, button_widget
#}

{#────────────────────────────  Row  ────────────────────────────#}
{% block form_row -%}
    {%- set row_attr = row_attr|merge({class: (row_attr.class|default(''))|trim ~ ' mb-4'})|filter((v, k) => v is not empty) -%}
    <div {% with { attr: row_attr } %}{{ block('attributes') }}{% endwith %}>
        {{- form_label(form) -}}
        {{- form_widget(form) -}}
        {{- form_help(form) -}}
        {{- form_errors(form) -}}
    </div>
{%- endblock form_row %}

{#────────────────────────────  Label  ────────────────────────────#}
{% block form_label -%}
    {%- if label is not same as(false) -%}
        {%- if compound is defined and compound -%}
            {%- set element = 'legend' -%}
            {%- set label_attr = label_attr|merge({class: (label_attr.class|default(''))|trim ~ ' block text-xs font-bold uppercase tracking-wide text-text-soft mb-1.5'}) -%}
        {%- else -%}
            {%- set label_attr = label_attr|merge({for: id, class: (label_attr.class|default(''))|trim ~ ' block text-xs font-bold uppercase tracking-wide text-text-soft mb-1.5'}) -%}
        {%- endif -%}
        {%- if required -%}
            {%- set label_attr = label_attr|merge({class: (label_attr.class|default(''))|trim ~ ' required'}) -%}
        {%- endif -%}
        {%- if label is empty -%}
            {%- if label_format is not empty -%}
                {%- set label = label_format|replace({'%name%': name, '%id%': id}) -%}
            {%- else -%}
                {%- set label = name|humanize -%}
            {%- endif -%}
        {%- endif -%}
        <{{ element|default('label') }}{% for attrname, attrvalue in label_attr %} {{ attrname }}="{{ attrvalue }}"{% endfor %}>
            {{- label|trans(label_translation_parameters, translation_domain) -}}
            {%- if required %} <span class="text-error">*</span>{% endif -%}
        </{{ element|default('label') }}>
    {%- endif -%}
{%- endblock form_label %}

{#────────────────────────────  Widget simple (input)  ────────────────────────────#}
{%- block form_widget_simple -%}
    {%- set type = type|default('text') -%}
    {%- set field_classes = 'block w-full bg-surface-200 text-text-primary border border-border rounded-sm px-3 py-2 text-sm font-display placeholder:text-text-muted transition-colors duration-150 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent disabled:opacity-50 disabled:cursor-not-allowed' -%}
    {%- if errors is defined and errors|length > 0 -%}
        {%- set field_classes = field_classes ~ ' border-error' -%}
    {%- endif -%}
    {%- set attr = attr|merge({class: (attr.class|default(''))|trim ~ ' ' ~ field_classes}) -%}
    <input type="{{ type }}" {{ block('widget_attributes') }} {% if value is not empty %}value="{{ value }}" {% endif %}/>
{%- endblock form_widget_simple -%}

{#────────────────────────────  Textarea  ────────────────────────────#}
{%- block textarea_widget -%}
    {%- set field_classes = 'block w-full bg-surface-200 text-text-primary border border-border rounded-sm px-3 py-2 text-sm font-display placeholder:text-text-muted transition-colors duration-150 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent disabled:opacity-50' -%}
    {%- if errors is defined and errors|length > 0 -%}
        {%- set field_classes = field_classes ~ ' border-error' -%}
    {%- endif -%}
    {%- set attr = attr|merge({class: (attr.class|default(''))|trim ~ ' ' ~ field_classes}) -%}
    <textarea {{ block('widget_attributes') }}>{{ value }}</textarea>
{%- endblock textarea_widget -%}

{#────────────────────────────  Select  ────────────────────────────#}
{%- block choice_widget_collapsed -%}
    {%- set field_classes = 'block w-full bg-surface-200 text-text-primary border border-border rounded-sm px-3 py-2 text-sm font-display transition-colors duration-150 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent disabled:opacity-50' -%}
    {%- if errors is defined and errors|length > 0 -%}
        {%- set field_classes = field_classes ~ ' border-error' -%}
    {%- endif -%}
    {%- set attr = attr|merge({class: (attr.class|default(''))|trim ~ ' ' ~ field_classes}) -%}
    <select {{ block('widget_attributes') }}{% if multiple %} multiple="multiple"{% endif %}>
        {%- if placeholder is not none -%}
            <option value=""{% if required and value is empty %} selected="selected"{% endif %}>
                {{ placeholder != '' ? (translation_domain is same as(false) ? placeholder : placeholder|trans({}, translation_domain)) }}
            </option>
        {%- endif -%}
        {%- if preferred_choices|length > 0 -%}
            {% set options = preferred_choices %}{{ block('choice_widget_options') }}
            {%- if choices|length > 0 and separator is not none -%}
                <option disabled="disabled">{{ separator }}</option>
            {%- endif -%}
        {%- endif -%}
        {%- set options = choices -%}
        {{- block('choice_widget_options') -}}
    </select>
{%- endblock choice_widget_collapsed -%}

{#────────────────────────────  Checkbox  ────────────────────────────#}
{%- block checkbox_widget -%}
    <label class="inline-flex items-center gap-2 cursor-pointer select-none">
        {%- set attr = attr|merge({class: (attr.class|default(''))|trim ~ ' w-4 h-4 rounded-sm bg-surface-300 border border-border-medium text-accent focus:ring-accent focus:ring-2 focus:ring-offset-0'}) -%}
        <input type="checkbox" {{ block('widget_attributes') }} {% if value is defined %}value="{{ value }}"{% endif %}{% if checked %} checked="checked"{% endif %} />
        <span class="text-sm text-text-soft">{{ label|default('')|trans(label_translation_parameters|default({}), translation_domain) }}</span>
    </label>
{%- endblock checkbox_widget -%}

{%- block checkbox_row -%}
    <div class="mb-4">
        {{- form_widget(form) -}}
        {{- form_errors(form) -}}
        {{- form_help(form) -}}
    </div>
{%- endblock checkbox_row -%}

{#────────────────────────────  Radio  ────────────────────────────#}
{%- block radio_widget -%}
    {%- set attr = attr|merge({class: (attr.class|default(''))|trim ~ ' w-4 h-4 bg-surface-300 border border-border-medium text-accent focus:ring-accent focus:ring-2'}) -%}
    <input type="radio" {{ block('widget_attributes') }} {% if value is defined %}value="{{ value }}"{% endif %}{% if checked %} checked="checked"{% endif %} />
{%- endblock radio_widget -%}

{#────────────────────────────  Submit & Button  ────────────────────────────#}
{%- block submit_widget -%}
    {%- set attr = attr|merge({class: (attr.class|default(''))|trim ~ ' inline-flex items-center justify-center gap-2 bg-transparent text-text-primary font-display font-bold uppercase tracking-wide text-sm px-4 py-2 rounded-md border-2 border-accent hover:bg-accent hover:text-bg transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-accent disabled:opacity-50'}) -%}
    {{- block('button_widget') -}}
{%- endblock submit_widget -%}

{%- block button_widget -%}
    {%- if label is empty -%}
        {%- if label_format is not empty -%}
            {%- set label = label_format|replace({'%name%': name, '%id%': id}) -%}
        {%- else -%}
            {%- set label = name|humanize -%}
        {%- endif -%}
    {%- endif -%}
    <button type="{{ type|default('button') }}" {{ block('button_attributes') }}>
        {{- translation_domain is same as(false) ? label : label|trans(label_translation_parameters, translation_domain) -}}
    </button>
{%- endblock button_widget -%}

{#────────────────────────────  Errors  ────────────────────────────#}
{%- block form_errors -%}
    {%- if errors|length > 0 -%}
        <ul class="mt-1.5 list-none p-0 space-y-1">
            {%- for error in errors -%}
                <li class="text-xs text-error flex items-center gap-1.5">
                    <i class="fa-solid fa-circle-exclamation text-[0.7rem]" aria-hidden="true"></i>
                    <span>{{ error.message }}</span>
                </li>
            {%- endfor -%}
        </ul>
    {%- endif -%}
{%- endblock form_errors -%}

{#────────────────────────────  Help  ────────────────────────────#}
{%- block form_help -%}
    {%- if help is not empty -%}
        {%- set help_attr = help_attr|merge({class: (help_attr.class|default(''))|trim ~ ' mt-1 text-xs text-text-muted'}) -%}
        <p{% for attrname, attrvalue in help_attr %} {{ attrname }}="{{ attrvalue }}"{% endfor %}>
            {{- (translation_domain is same as(false) ? help : help|trans(help_translation_parameters, translation_domain))|raw -}}
        </p>
    {%- endif -%}
{%- endblock form_help -%}
