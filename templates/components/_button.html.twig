{#
  components/_button.html.twig — Bouton NVIDIA dark

  Pattern NVIDIA : fond transparent + bordure verte 2px par défaut, texte blanc,
  hover bascule sur fond teal (#1eaedb).

  Usage :
    {% include 'components/_button.html.twig' with {
      label: 'Enregistrer',
      variant: 'accent',
      size: 'md',
      type: 'submit',
    } only %}

    {% include 'components/_button.html.twig' with {
      label: 'Nouveau client',
      variant: 'primary',
      href: path('admin.customer.create'),
      icon: 'fa-solid fa-plus',
    } only %}

  Params :
    label        string  texte du bouton (obligatoire)
    variant      string  primary | accent | ghost | danger | success | pill  (default: primary)
    size         string  sm | md | lg  (default: md)
    href         string  si défini → <a>, sinon <button>
    type         string  pour <button> : button | submit  (default: button)
    icon         string  classe FontAwesome ('fa-solid fa-plus')
    icon_right   bool    icône à droite plutôt qu'à gauche
    extra_class  string  classes Tailwind additionnelles
    disabled     bool    désactivé
    title        string  attribut HTML title
#}

{%- set _base = 'inline-flex items-center justify-center gap-2 font-display font-bold uppercase tracking-wide transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-accent disabled:opacity-50 disabled:cursor-not-allowed' -%}

{%- set _sizes = {
  sm: 'text-xs px-3 py-1.5 rounded-sm border',
  md: 'text-sm px-4 py-2 rounded-md border-2',
  lg: 'text-base px-6 py-2.5 rounded-md border-2',
} -%}

{%- set _variants = {
  primary: 'bg-transparent text-text-primary border-accent hover:bg-btn-hover hover:border-btn-hover',
  accent:  'bg-transparent text-text-primary border-accent hover:bg-accent hover:text-bg',
  ghost:   'bg-transparent text-text-soft border-transparent hover:text-text-primary hover:border-border',
  danger:  'bg-transparent text-error border-error hover:bg-error hover:text-text-primary',
  success: 'bg-transparent text-accent border-accent hover:bg-accent hover:text-bg',
  pill:    'bg-surface-300 text-text-soft border-transparent rounded-pill hover:text-error px-3 py-1 text-xs',
} -%}

{%- set _size_class = _sizes[size|default('md')] -%}
{%- set _variant_class = _variants[variant|default('primary')] -%}
{%- set _classes = _base ~ ' ' ~ _size_class ~ ' ' ~ _variant_class ~ ' ' ~ (extra_class|default('')) -%}

{%- if href is defined and href -%}
  <a href="{{ href }}" class="{{ _classes }}"{% if title is defined %} title="{{ title }}"{% endif %}>
    {%- if icon is defined and icon and not (icon_right|default(false)) %}<i class="{{ icon }}" aria-hidden="true"></i>{% endif -%}
    <span>{{ label }}</span>
    {%- if icon is defined and icon and icon_right|default(false) %}<i class="{{ icon }}" aria-hidden="true"></i>{% endif -%}
  </a>
{%- else -%}
  <button type="{{ type|default('button') }}" class="{{ _classes }}"
    {%- if disabled|default(false) %} disabled{% endif -%}
    {%- if title is defined %} title="{{ title }}"{% endif -%}
  >
    {%- if icon is defined and icon and not (icon_right|default(false)) %}<i class="{{ icon }}" aria-hidden="true"></i>{% endif -%}
    <span>{{ label }}</span>
    {%- if icon is defined and icon and icon_right|default(false) %}<i class="{{ icon }}" aria-hidden="true"></i>{% endif -%}
  </button>
{%- endif -%}
