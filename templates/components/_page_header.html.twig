{#
  components/_page_header.html.twig — En-tête de page NVIDIA dark

  Style : titre bold 36px + sous-titre gris soft, séparateur vert accent.

  Usage :
    {% include 'components/_page_header.html.twig' with {
      title: 'Clients',
      subtitle: 'Gestion des comptes clients et crédits',
    } only %}

  Avec slot actions (boutons à droite) :
    {% embed 'components/_page_header.html.twig' with {
      title: 'Produits',
      subtitle: 'Catalogue et stocks',
    } only %}
      {% block actions %}
        {% include 'components/_button.html.twig' with {
          label: 'Nouveau produit',
          variant: 'accent',
          icon: 'fa-solid fa-plus',
          href: path('admin.product.create'),
        } only %}
      {% endblock %}
    {% endembed %}

  Params :
    title       string  titre principal (obligatoire)
    subtitle    string  sous-titre (optionnel)
    extra_class string  classes additionnelles sur le conteneur
#}

<header class="mb-7 pb-5 border-b-2 border-accent flex flex-col gap-1 md:flex-row md:items-end md:justify-between md:gap-6 {{ extra_class|default('') }}">
  <div class="flex flex-col gap-1.5 min-w-0">
    <h1 class="m-0 truncate">{{ title }}</h1>
    {%- if subtitle is defined and subtitle %}
      <p class="m-0 text-base text-text-soft">{{ subtitle }}</p>
    {%- endif %}
  </div>

  {%- if block('actions') is defined %}
    <div class="flex flex-wrap items-center gap-2 shrink-0">
      {% block actions %}{% endblock %}
    </div>
  {%- endif %}
</header>
